{
  "manifest_version": 3,
  "name": "ZarPresence",
  "version": "1.0.1",
  "author": "ZarScape",
  "description": "Modern Discord Rich Presence, redefined.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.crunchyroll.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.crunchyroll.com/*"],
      "js": ["crunchyroll.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
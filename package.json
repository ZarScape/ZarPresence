{
  "name": "zarpresence",
  "private": true,
  "version": "1.0.2",
  "author": "ZarScape",
  "description": "Modern Discord Rich Presence, redefined.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "tsc -b && vite build",
    "build:extension": "vite build -c vite.extension.config.ts && copy src\\extension\\manifest.json dist-extension\\manifest.json && xcopy /s /e /i src\\extension\\icons dist-extension\\icons",
    "build": "npm run build:client && npm run build:extension",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.6.0",
    "lucide-react": "latest",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@tauri-apps/api": "^1.6.0",
    "@tauri-apps/cli": "^1.6.3",
    "@types/chrome": "^0.0.309",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
